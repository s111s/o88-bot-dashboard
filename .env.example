# Copy this file to .env (which is git-ignored) and fill in the values.
# Never commit .env. Never paste these values into any chat.

# ── Keeper wallet (Bot K-redeem) ─────────────────────────────────────────────
# Sui private key in the Bech32/sui-import format starting with "suiprivkey1...".
# Generate with: sui keytool generate ed25519
# Then export via:  sui keytool export <ADDR> --key-identity ed25519
# Or read from your keystore at ~/.sui/sui_config/sui.keystore (base64 line).
O88_KEEPER_PRIVATE_KEY=

# The matching public address (for monitoring + logging).
# We use this in the dashboard to highlight our own redemptions.
O88_KEEPER_ADDRESS=

# ── Network ──────────────────────────────────────────────────────────────────
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ── Predict (testnet) ────────────────────────────────────────────────────────
PREDICT_PACKAGE=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_OBJECT=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_REGISTRY=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
DUSDC_COIN_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# ── Bot K-redeem behavior ────────────────────────────────────────────────────
# Skip positions smaller than this (avoid wasting gas on dust).
# DUSDC atomic units (6 decimals). 100_000 = $0.10.
O88_MIN_REDEEM_PAYOUT_ATOMIC=100000

# Don't try to redeem more than this many positions in one PTB (Sui command cap).
O88_MAX_REDEEMS_PER_PTB=20

# Polling cadence — how often to scan for new candidates.
O88_SCAN_INTERVAL_SECS=30
